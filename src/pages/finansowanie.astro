---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout>
  <section class="py-24 bg-white">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl mx-auto text-center">
        <h1 class="text-4xl md:text-5xl font-bold text-slate-900 mb-6">
          Finansowanie
        </h1>
        <p class="text-slate-600 leading-relaxed mb-8">
          Oferujemy elastyczne opcje finansowania naszych usług. Dowiedz się więcej o dostępnych planach płatności.
        </p>
        
        <div class="bg-blue-50 rounded-3xl p-8 lg:p-12">
          <h2 class="text-slate-900 mb-6">
            Opcje Finansowania
          </h2>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-8 text-left">
            <div>
              <h3 class="text-slate-900 mb-3">Płatność pełna</h3>
              <p class="text-slate-600">
                Zarezerwuj termin i zapłać pełną kwotę za usługę, uzyskując dostęp do pełnych benefitów.
              </p>
            </div>
            <div>
              <h3 class="text-slate-900 mb-3">Raty</h3>
              <p class="text-slate-600">
                Podziel płatność na wygodne raty bez dodatkowych odsetek i ukrytych opłat.
              </p>
            </div>
          </div>
        </div>

        <div class="mt-12">
          <a 
            href="/kontakt" 
            class="inline-flex items-center px-8 py-4 bg-blue-600 text-white font-semibold rounded-full hover:bg-blue-700 transition-all duration-300 shadow-lg hover:shadow-xl transform hover:-translate-y-0.5"
          >
            Skontaktuj się z nami
            <svg 
              class="ml-2 w-5 h-5" 
              fill="none" 
              stroke="currentColor" 
              viewBox="0 0 24 24"
            >
              <path 
                stroke-linecap="round" 
                stroke-linejoin="round" 
                stroke-width="2" 
                d="M17 8l4 4m0 0l-4 4m4-4H3" 
              />
            </svg>
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
