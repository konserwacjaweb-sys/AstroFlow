---
import BaseLayout from '@layouts/BaseLayout.astro';
import Section from '@components/ui/Section.astro';
import Card from '@components/ui/Card.astro';
import ImageReveal from '@components/react/ImageReveal';
import { Image } from 'astro:assets';

import heroBgImg from '@assets/photo-1454165804606-c3d57bc86b40.jpg';

const faqs = [
  {
    question: 'How do I access the customer portal?',
    answer: 'Contact your account manager to receive login credentials for our secure customer portal. Once registered, you can track shipments, view inventory, generate reports, and manage your account 24/7 from anywhere in the world.'
  },
  {
    question: 'What file formats are supported for EDI?',
    answer: 'We support all standard EDI formats including X12 (850, 856, 810, 997, etc.), EDIFACT, and custom XML formats. Our integration team can work with your existing systems to ensure seamless data exchange and compatibility.'
  },
  {
    question: 'Where can I find safety data sheets (SDS)?',
    answer: 'All safety data sheets are available in the Compliance & Certifications section of our documentation center. You can also request specific SDS documents directly from your account manager or through our support portal.'
  },
  {
    question: 'How often is documentation updated?',
    answer: 'Our FAQ is reviewed and updated quarterly, or more frequently as needed for regulatory changes, system updates, or process improvements. You will be notified of any critical updates via email and through the customer portal.'
  },
  {
    question: 'Can I download multiple documents at once?',
    answer: 'Yes, you can select multiple documents and download them as a ZIP archive. Simply use the bulk selection feature available in each category section to download multiple files simultaneously.'
  },
  {
    question: 'Is there a mobile app for accessing documentation?',
    answer: 'Yes, our mobile application is available for both iOS and Android devices. You can download it from the App Store or Google Play Store. The app provides full access to all documentation and features offline reading capabilities.'
  }
];
---

<BaseLayout title="FAQ - Frequently Asked Questions">
  <!-- Hero Section -->
  <section class="relative h-[500px] md:h-[600px] flex items-center overflow-hidden">
    <div class="absolute inset-0">
      <Image 
        src={heroBgImg}
        alt="FAQ and support"
        class="w-full h-full object-cover"
        width={2070}
        height={1380}
      />
      <div class="absolute inset-0 bg-linear-to-r from-slate-900/95 via-slate-900/85 to-slate-900/70"></div>
      <div class="absolute inset-0 bg-[radial-gradient(circle_at_50%_50%,rgba(59,130,246,0.1),transparent_70%)]"></div>
    </div>

    <div class="container mx-auto relative z-10 px-4 sm:px-6 lg:px-8">
      <div class="max-w-4xl mx-auto text-center">
        <div class="inline-flex items-center px-4 py-2 mb-6 bg-linear-to-r from-blue-600 to-teal-600 text-white text-sm font-semibold rounded-full shadow-lg">
          <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          Quick Answers
        </div>
        
        <h1 class="text-4xl md:text-6xl lg:text-7xl font-bold text-white mb-6 leading-tight">
          Frequently Asked <span class="text-transparent bg-clip-text bg-linear-to-r from-blue-400 via-teal-400 to-blue-400">Questions</span>
        </h1>
        
        <p class="text-slate-200 mb-8 max-w-3xl mx-auto leading-relaxed">
          Find answers to common questions about our services and how to get the most out of our platform.
        </p>
      </div>
    </div>
  </section>

  <!-- Search Bar -->
  <Section background="gray">
    <div class="max-w-4xl mx-auto mb-16">
      <Card class="p-6 shadow-xl border-2 border-gray-100">
        <div class="flex flex-col md:flex-row gap-4">
          <div class="flex-1 relative">
            <svg class="absolute left-4 top-1/2 -translate-y-1/2 w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
            </svg>
            <input
              type="text"
              placeholder="Search FAQ..."
              class="w-full pl-12 pr-4 py-4 border-2 border-gray-200 rounded-xl focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-all text-lg"
            />
          </div>
          <button class="bg-linear-to-r from-blue-600 to-teal-600 text-white px-8 py-4 rounded-xl font-semibold hover:from-blue-700 hover:to-teal-700 transition-all shadow-lg hover:shadow-xl flex items-center justify-center gap-2">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
            </svg>
            Search
          </button>
        </div>
      </Card>
    </div>
  </Section>

  <!-- FAQ Section -->
  <Section background="white">
    <div class="text-center mb-16">
      <h2 class="text-gray-900 mb-4">
        Popular Questions
      </h2>
      <p class="text-gray-600 max-w-3xl mx-auto">
        Browse our most frequently asked questions. Still can't find what you're looking for? <a href="/kontakt" class="text-blue-600 hover:text-blue-800 font-semibold">Contact our support team</a>.
      </p>
    </div>

    <div class="max-w-4xl mx-auto space-y-4">
      {faqs.map((faq, index) => (
        <ImageReveal client:load delay={index * 0.05}>
          <Card hover class="border-2 border-gray-100 hover:border-blue-200 transition-colors">
            <details class="group">
              <summary class="flex items-center justify-between cursor-pointer list-none py-2 group-open:mb-2 [&::-webkit-details-marker]:hidden">
                <h3 class="text-gray-900 pr-4 group-hover:text-blue-600 transition-colors">
                  {faq.question}
                </h3>
                <div class="shrink-0">
                  <svg class="w-5 h-5 text-gray-400 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                  </svg>
                </div>
              </summary>
              <div class="mt-4 pt-4 border-t border-gray-100">
                <p class="text-gray-600 leading-relaxed">{faq.answer}</p>
              </div>
            </details>
          </Card>
        </ImageReveal>
      ))}
    </div>
  </Section>

  <!-- Help Section -->
  <Section background="gradient">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-12">
        <h2 class="text-gray-900 mb-4">
          Need More <span class="text-transparent bg-clip-text bg-linear-to-r from-blue-600 to-teal-600">Help?</span>
        </h2>
        <p class="text-gray-600 max-w-3xl mx-auto">
          Our team is here to assist you with any questions or support you need.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <ImageReveal client:load delay={0}>
          <Card hover class="text-center h-full">
            <div class="w-20 h-20 bg-linear-to-br from-blue-500 to-cyan-500 rounded-2xl flex items-center justify-center mx-auto mb-6 shadow-xl">
              <svg class="w-10 h-10 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
            </div>
            <h3 class="text-gray-900 mb-3">Phone Support</h3>
            <p class="text-gray-600 mb-6">
              Speak with a representative Monday-Friday, 9 AM - 6 PM EST
            </p>
            <a href="tel:+1234567890" class="inline-flex items-center gap-2 text-blue-600 hover:text-blue-800 font-semibold group">
              Call Us
              <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
            </a>
          </Card>
        </ImageReveal>

        <ImageReveal client:load delay={0.1}>
          <Card hover class="text-center h-full">
            <div class="w-20 h-20 bg-linear-to-br from-purple-500 to-pink-500 rounded-2xl flex items-center justify-center mx-auto mb-6 shadow-xl">
              <svg class="w-10 h-10 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
            </div>
            <h3 class="text-gray-900 mb-3">Email Support</h3>
            <p class="text-gray-600 mb-6">
              Request support via email and we'll respond within 24 hours
            </p>
            <a href="mailto:support@example.com" class="inline-flex items-center gap-2 text-blue-600 hover:text-blue-800 font-semibold group">
              Send Email
              <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
            </a>
          </Card>
        </ImageReveal>

        <ImageReveal client:load delay={0.2}>
          <Card hover class="text-center h-full">
            <div class="w-20 h-20 bg-linear-to-br from-green-500 to-emerald-500 rounded-2xl flex items-center justify-center mx-auto mb-6 shadow-xl">
              <svg class="w-10 h-10 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4" />
              </svg>
            </div>
            <h3 class="text-gray-900 mb-3">Knowledge Base</h3>
            <p class="text-gray-600 mb-6">
              Browse our comprehensive documentation and technical guides
            </p>
            <a href="/documentation" class="inline-flex items-center gap-2 text-blue-600 hover:text-blue-800 font-semibold group">
              View Docs
              <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
            </a>
          </Card>
        </ImageReveal>
      </div>
    </div>
  </Section>
</BaseLayout>

