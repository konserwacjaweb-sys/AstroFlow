---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout>
  <section class="py-24 bg-linear-to-b from-blue-50 to-white">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl mx-auto text-center">
        <div class="inline-block px-4 py-2 mb-6 bg-blue-100 text-blue-600 text-sm font-semibold rounded-full">
          Eksklusywna Oferta
        </div>
        
        <h1 class="text-4xl md:text-5xl font-bold text-slate-900 mb-6">
          Oferta Specjalna
        </h1>
        <p class="text-xl text-slate-600 leading-relaxed mb-12">
          Skorzystaj z naszych eksklusywnych promocji i specjalnych pakietów usług dostępnych przez ograniczony czas.
        </p>
        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          <div class="bg-white rounded-3xl shadow-xl border-2 border-blue-600 p-8">
            <div class="inline-block px-4 py-2 mb-4 bg-blue-600 text-white text-sm font-semibold rounded-full">
              Popularna
            </div>
            <h3 class="text-2xl font-bold text-slate-900 mb-4">
              Pakiet Makijażu
            </h3>
            <p class="text-slate-600 mb-6">
              Makijaż permanentny brwi + powiększanie ust z 20% rabatem
            </p>
            <div class="text-4xl font-bold text-blue-600 mb-6">
              -20%
            </div>
            <a 
              href="/oferta" 
              class="inline-block w-full px-8 py-4 bg-blue-600 text-white font-semibold rounded-full hover:bg-blue-700 transition-all duration-300"
            >
              Rezerwuj Teraz
            </a>
          </div>

          <div class="bg-white rounded-3xl shadow-lg p-8">
            <h3 class="text-2xl font-bold text-slate-900 mb-4">
              Voucher Podarunkowy
            </h3>
            <p class="text-slate-600 mb-6">
              Kup voucher i podaruj idealny prezent bliskiej osobie
            </p>
            <div class="text-4xl font-bold text-slate-900 mb-6">
              Od 100 zł
            </div>
            <a 
              href="/galeria" 
              class="inline-block w-full px-8 py-4 bg-slate-200 text-slate-900 font-semibold rounded-full hover:bg-slate-300 transition-all duration-300"
            >
              Więcej Informacji
            </a>
          </div>
        </div>

        <div class="mt-12 p-8 bg-warning-50 rounded-2xl border-2 border-yellow-200">
          <p class="text-sm text-slate-600">
            ⏰ Oferta ważna do konca miesiąca. Zarezerwuj swój termin teraz!
          </p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
