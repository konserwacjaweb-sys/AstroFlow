---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout>
  <section class="py-24 bg-white">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl mx-auto text-center">
        <h1 class="text-4xl md:text-5xl font-bold text-slate-900 mb-6">
          Blog
        </h1>
        <p class="text-slate-600 leading-relaxed mb-12">
          Przeczytaj nasze najnowsze artykuły i porady dotyczące pielęgnacji, kosmetyki i trendów urodowych.
        </p>
        
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          {[1, 2, 3, 4, 5, 6].map((item) => (
            <article class="bg-slate-50 rounded-2xl overflow-hidden hover:shadow-lg transition-all duration-300">
              <div class="h-48 bg-gradient-to-br from-blue-400 to-purple-500"></div>
              <div class="p-6">
                <h3 class="text-slate-900 mb-3">
                  Artykuł {item}
                </h3>
                <p class="text-slate-600 mb-4">
                  Odkryj nowe trendy i porady dotyczące pielęgnacji i urody.
                </p>
                <a href="#" class="text-blue-600 font-semibold hover:text-blue-700">
                  Czytaj więcej →
                </a>
              </div>
            </article>
          ))}
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
