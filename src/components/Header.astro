---
import { NAVIGATION } from '@config/site';

import { MapPin, Package, Phone, Mail } from 'lucide-react';
import MobileMenu from '@components/react/MobileMenu';

const { currentPathname } = Astro.props;
const isActiveLink = (href: string) : boolean => { return href === currentPathname; }

---

<!-- Top Bar - normalny flow, nie na premium-hero -->
<div class="top-bar border-b border-slate-200 bg-slate-50 w-full z-40">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex h-10 items-center justify-between text-sm">
      <div class="flex items-center gap-6">
        <a
          href="https://maps.app.goo.gl/sGgGBwZ52NhQ6kCN9"
          class="inline-flex items-center gap-2 text-slate-600 hover:text-blue-600 transition-colors"
        >
          <MapPin className="h-4 w-4" />
          <span class="hidden sm:inline">Kościerzyna, Moniuszki 1</span>
        </a>
        <a
          href="tel:+48123456789"
          class="hidden md:inline-flex items-center gap-2 text-slate-600 hover:text-blue-600 transition-colors"
        >
          <Phone className="h-4 w-4" />
          <span>+48 123 456 789</span>
        </a>
      </div>
      <a
        href="mailto:kontakt@wioletaliterska.pl"
        class="hidden sm:inline-flex items-center gap-2 text-slate-600 hover:text-blue-600 transition-colors"
      >
        <Mail className="h-4 w-4" />
        <span>kontakt@wioletaliterska.pl</span>
      </a>
    </div>
  </div>
</div>

<!-- Nav - fixed, na premium-hero -->
<header class="site-header fixed top-10 left-0 right-0 z-50 w-full transition-all duration-300" data-site-header>
  <nav class="container mx-auto flex h-20 items-center justify-between px-4 sm:px-6 lg:px-2">
    <!-- Logo -->
    <div class="flex items-center header-logo">
      <a href="/" class="flex items-center group">
        <img
          src="/wioleta_literska_logo.png"
          alt="Wioleta Literska Logo"
          class="object-contain"
          width="218"
          height="70"
          decoding="async"
          fetchpriority="high"
        />
      </a>
    </div>

    <!-- Desktop Navigation -->
    <div class="hidden lg:flex lg:items-center lg:space-x-1">
      {NAVIGATION.map((item) => {
        const isActive = isActiveLink(item.href);
        return (
        <a
          href={item.href}
          class={`nav-link px-4 py-2 text-sm font-medium text-white hover:text-blue-400 hover:bg-white/10 rounded-lg transition-all relative group ${isActive ? 'nav-active' : ''}`}
        >
          {item.name}
        </a>
      );
      })}
    </div>

    <div class="hidden lg:flex lg:items-center">
      <!-- CTA Button -->
      <div>
        <a
          href="/kontakt"
          class="inline-flex items-center px-6 py-2.5 text-sm font-semibold text-white bg-linear-to-r from-blue-600 to-blue-700 hover:from-blue-700 hover:to-blue-800 rounded-lg shadow-md hover:shadow-lg transition-all"
        >
          Kontakt
        </a>
      </div>
    </div>

    <!-- Mobile Menu Button -->
    <MobileMenu client:idle />
  </nav>
</header>

<script>
  const header = document.querySelector('[data-site-header]');
  
  const handleScroll = () => {
    if (window.scrollY > 50) {
      header?.classList.add('is-sticky');
    } else {
      header?.classList.remove('is-sticky');
    }
  };

  window.addEventListener('scroll', handleScroll);
  handleScroll();
</script>
