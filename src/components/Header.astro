---
import { NAVIGATION } from '@config/site';

import { Phone } from 'lucide-react';
import { FontAwesomeIcon } from '@fortawesome/react-fontawesome';
import { faLocationDot } from '@fortawesome/free-solid-svg-icons';
import MobileMenu from '@components/react/MobileMenu';

const { currentPathname } = Astro.props;
const isActiveLink = (href: string) : boolean => { return href === currentPathname; }

---

<!-- Nav - nałożona na premium-hero -->
<header class="site-header absolute top-0 left-0 right-0 z-50 w-full transition-all duration-300" data-site-header>
  <!-- Top Bar -->
  <div class="top-bar border-b border-slate-200 bg-slate-50 w-full">
    <div class="container mx-auto py-2 px-4 sm:px-6 lg:px-8">
      <div class="flex h-10 items-center justify-end text-x1">
        <div class="flex items-center gap-8">
          <a
            href="tel:+48695239434"
            class="hidden md:inline-flex items-center gap-4 text-slate-600 hover:text-blue-600 transition-colors"
          >
            <Phone className="h-4 w-4" fill="currentColor" />
            <span>Gabinet Kościerzyna<br/>+48 695 239 434</span>
          </a>
          <a
            href="https://maps.app.goo.gl/sGgGBwZ52NhQ6kCN9"
            class="inline-flex items-center gap-4 text-slate-600 hover:text-blue-600 transition-colors"
          >
            <FontAwesomeIcon icon={faLocationDot} className="h-4 w-4" />
            <span class="hidden sm:inline">Znajdź lokalizację</span>
          </a>
        </div>
      </div>
    </div>
  </div>
  <nav class="container mx-auto flex items-center justify-between px-4 sm:px-6 lg:px-2" style="min-height: 160px;">
    <!-- Logo -->
    <div class="flex items-center header-logo">
      <a href="/" class="flex items-center group">
        <img
          src="/white-circle-logo.png"
          alt="Wioleta Literska Logo"
          class="object-contain"
          width="246"
          height="140"
          decoding="async"
          fetchpriority="high"
        />
      </a>
    </div>

    <!-- Desktop Navigation -->
    <div class="hidden lg:flex lg:items-center lg:space-x-1">
      {NAVIGATION.map((item) => {
        const isActive = isActiveLink(item.href);
        return (
<a href={item.href} class={`nav-link mx-2 px-4 py-2 text-[1.0625rem] font-normal text-white hover:text-blue-400 hover:bg-white/10 rounded-lg transition-all relative group ${isActive ? 'nav-active' : ''}`} > {item.name} </a> ); })}
    </div>

    <div class="hidden lg:flex lg:items-center">
      <!-- CTA Button -->
      <div>
        <a
          href="/kontakt"
          class="inline-flex items-center px-6 py-2.5 text-[1.0625rem] font-normal text-[#bf9752] border-1 border-[#bf9752]bg-transparent rounded-[13px] hover:shadow-lg transition-all"
        >
          Kontakt
        </a>
      </div>
    </div>

    <!-- Mobile Menu Button -->
    <MobileMenu client:idle />
  </nav>
</header>

<script>
  const header = document.querySelector('[data-site-header]');
  const sections = document.querySelectorAll('main section');
  const firstSection = sections[0];

  if (header && firstSection) {
    const observer = new IntersectionObserver(
      ([entry]) => {
        // Sticky od drugiej sekcji (po opuszczeniu pierwszej)
        header.classList.toggle('is-sticky', !entry.isIntersecting);
      },
      { threshold: 0, rootMargin: '0px' }
    );

    observer.observe(firstSection);
  } else if (header) {
    header.classList.add('is-sticky');
  }
</script>
