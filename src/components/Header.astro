---
import { NAVIGATION } from '@config/site';

import { MapPin, Package } from 'lucide-react';
import MobileMenu from '@components/react/MobileMenu';

const { currentPathname } = Astro.props;
const isActiveLink = (href: string) : boolean => { return href === currentPathname; }

---

<header class="site-header z-50 w-full border-b border-slate-200 bg-white/95 backdrop-blur-md shadow-sm" data-site-header>
  <nav class="container mx-auto flex h-20 items-center justify-between px-4 sm:px-6 lg:px-2">
    <!-- Logo -->
    <div class="flex items-center header-logo">
      <a href="/" class="flex items-center group">
        <img
          src="/wioleta_literska_logo.png"
          alt="Wioleta Literska Logo"
          class="object-contain"
          width="218"
          height="70"
          decoding="async"
          fetchpriority="high"
        />
      </a>
    </div>

    <!-- Desktop Navigation -->
    <div class="hidden lg:flex lg:items-center lg:space-x-1">
      {NAVIGATION.map((item) => {
        const isActive = isActiveLink(item.href);
        return (
        <a
          href={item.href}
          class={`px-4 py-2 text-sm font-medium text-slate-700 hover:text-blue-600 hover:bg-blue-50 rounded-lg transition-all relative group ${isActive ? 'nav-active' : ''}`}
        >
          {item.name}
        </a>
      );
      })}
    </div>

    <div class="hidden lg:flex lg:items-center">
      <div class="mr-4">
        <a
          href="https://maps.app.goo.gl/sGgGBwZ52NhQ6kCN9"
          class="inline-flex items-center gap-1 text-[0.875rem] leading-[1.2] text-slate-500 hover:text-slate-700 transition-colors"
        >
          <MapPin className="h-4 w-4 text-slate-500" />
          Lokalizacja Kościerzyna,<br/>Moniuszki 1
        </a>
      </div>
      <!-- CTA Button -->
      <div>
        <a
          href="/kontakt"
          class="inline-flex items-center px-6 p  y-2.5 text-sm font-semibold text-white bg-linear-to-r from-blue-600 to-blue-700 hover:from-blue-700 hover:to-blue-800 rounded-lg shadow-md hover:shadow-lg transition-all"
        >
          Kontakt
        </a>
      </div>
    </div>

    <!-- Mobile Menu Button -->
    <MobileMenu client:idle />
  </nav>
</header>

<script>
  const header = document.querySelector('[data-site-header]');
  const firstSection = document.querySelector('main > section');

  if (header && firstSection) {
    const observer = new IntersectionObserver(
      ([entry]) => {
        header.classList.toggle('is-sticky', !entry.isIntersecting);
      },
      { threshold: 0 }
    );

    observer.observe(firstSection);
  } else if (header) {
    header.classList.add('is-sticky');
  }
</script>
