---
interface Props {
  variant?: 'primary' | 'secondary' | 'outline' | 'default';
  size?: 'sm' | 'md' | 'lg';
  href?: string;
  class?: string;
}

const {
  variant = 'default',
  size = 'md',
  href,
  class: className = ''
} = Astro.props;

const baseStyles = 'inline-flex items-center justify-center font-semibold transition-all duration-200 shadow-md hover:shadow-lg active:scale-95 rounded-lg';

const variantStyles = {
  primary: 'border-2 border-[#999173] bg-[#999173] text-white hover:bg-[#999173]/90',
  secondary: 'border-2 border-[#999173] bg-transparent text-[#999173] hover:bg-[#999173]/10',
  outline: 'border-2 border-current bg-transparent',
  default: 'border-2 border-[#999173] bg-[#999173] text-white hover:bg-[#999173]/90'
};

const sizeStyles = {
  sm: 'px-4 py-2 text-sm',
  md: 'px-6 py-3 text-base',
  lg: 'px-6 py-4 text-normal'
};

const classes = `${baseStyles} ${variantStyles[variant]} ${sizeStyles[size]} ${className}`;

const Tag = href ? 'a' : 'button';
---

<Tag href={href} class={classes}>
    <slot />
</Tag>
