---
interface Props {
  variant?: 'primary' | 'secondary' | 'outline' | 'default';
  size?: 'sm' | 'md' | 'lg';
  href?: string;
  class?: string;
}

const {
  variant = 'default',
  size = 'md',
  href,
  class: className = ''
} = Astro.props;

const baseStyles = 'inline-flex items-center justify-center font-semibold transition-all duration-200 shadow-md hover:shadow-lg active:scale-95';

const variantStyles = {
  primary: '',
  secondary: '',
  outline: '',
  default: ''
};

const sizeStyles = {
  sm: 'px-4 py-2 text-sm',
  md: 'px-6 py-3 text-base',
  lg: 'px-6 py-4 text-normal'
};

const classes = `${baseStyles} ${variantStyles[variant]} ${sizeStyles[size]} ${className}`;

const Tag = href ? 'a' : 'button';
---

<Tag href={href} class={classes} data-ui-button>
    <slot />
</Tag>
