---
import { Image } from 'astro:assets';
import heroImage from '../../assets/makijaz-permanentny-bg.jpg';
import circleGoldBg from '../../assets/kolo.png';
import awardKbc from '../../assets/kbcaw.png';
import awardKbcChamp from '../../assets/art-beauty-logo.png';
import awardPmuGold from '../../assets/pmugold.png';

export interface Props {
  heading?: string;
  subheading?: string;
  circleHeading?: string;
  circleSubheading?: string;
}

const defaultHeading = 'Wioleta Literska';

const {
  heading = defaultHeading,
  subheading = 'Makijaż na okazje, który robi wrażenie zanim powiesz pierwsze słowo',
  circleHeading = 'Naturalny',
  circleSubheading = 'Efekt',
} = Astro.props;

const useDefaultHeading = heading === defaultHeading;

const badges = [
  {
    src: awardKbc,
    alt: 'KBC Awards - juror i prelegent',
    label: 'Juror i Prelegent',
  },
  {
    src: awardKbcChamp,
    alt: 'KBC Awards - juror',
    label: 'Juror - Modelowanie ust',
  },
  {
    src: awardPmuGold,
    alt: 'PMU Gold - certyfikacja master',
    label: 'Certyfikacja PMU Master',
  },
] as const;
---

<section class="relative flex min-h-[88vh] w-full items-end overflow-hidden md:min-h-screen">
  <Image
    src={heroImage}
    alt="Makijaż permanentny"
    class="absolute inset-0 h-full w-full object-cover object-center"
    loading="eager"
    quality="high"
  />

  <div class="absolute inset-0 bg-[linear-gradient(100deg,rgba(8,7,6,0.72)_15%,rgba(8,7,6,0.38)_46%,rgba(8,7,6,0.62)_100%)]"></div>
  <div class="absolute inset-x-0 bottom-0 h-40 bg-[linear-gradient(180deg,rgba(7,6,5,0)_0%,rgba(7,6,5,0.72)_100%)]"></div>

  <div class="relative z-10 w-full px-6 pb-12 pt-32 sm:px-8 sm:pb-14 sm:pt-40 lg:px-12 lg:pb-16 lg:pt-44">
    <div class="mx-auto flex w-full max-w-7xl flex-col gap-8 lg:gap-10">
      <div class="grid items-end gap-8 lg:grid-cols-[minmax(0,1.2fr)_minmax(260px,320px)] lg:gap-4">
        <div class="animate-slide-in-left text-left">
          <p class="mb-3 font-poppins text-[0.7rem] uppercase tracking-[0.42em] text-[#d7c6a6] sm:text-xs">
            Kościerzyna • Wejherowo Studio
          </p>

          <h2 class="font-notoDisplay text-4xl font-normal uppercase leading-[0.94] text-white sm:text-5xl lg:text-6xl xl:text-7xl">
            {useDefaultHeading ? (
              <>
                Makijaż Permanentny
                <span class="mt-3 block text-xl tracking-[0.28em] text-[#e8d8b9] sm:text-2xl lg:text-3xl">Powiększanie ust - Fresh Lips</span>
              </>
            ) : (
              heading
            )}
          </h2>

          <p class="mt-5 max-w-2xl font-poppins text-sm uppercase tracking-[0.18em] text-white/90 sm:text-base">
            {subheading}
          </p>

          <div class="mt-7 flex flex-wrap items-center gap-3">
            <a href="/kontakt" class="inline-flex items-center justify-center border border-[#d8c4a0] bg-[#baa586]/15 px-5 py-3 text-xs font-medium uppercase tracking-[0.22em] text-white transition-colors duration-300 hover:bg-[#baa586]/30 sm:text-sm">
              Umów konsultację
            </a>
            <a href="/galeria" class="inline-flex items-center justify-center border border-white/35 px-5 py-3 text-xs font-medium uppercase tracking-[0.22em] text-white transition-colors duration-300 hover:bg-white/10 sm:text-sm">
              Zobacz metamorfozy
            </a>
          </div>
        </div>

        <div class="animate-slide-in-right hidden w-full items-center justify-end lg:flex">
          <div class="relative h-64 w-64 lg:h-72 lg:w-72 xl:h-80 xl:w-80">
            <div class="absolute inset-0 rounded-full bg-white/10 backdrop-blur-[2px]"></div>
            <Image
              src={circleGoldBg}
              alt="Złote koło dekoracyjne"
              class="absolute inset-0 h-full w-full object-contain"
              loading="eager"
              quality="high"
            />

            <div class="relative z-10 flex h-full flex-col items-end justify-center text-right pr-7">
              <h4 class="font-notoDisplay text-4xl font-normal leading-tight text-white lg:text-5xl xl:text-6xl">
                {circleHeading}
                <br />
                <span class="text-6xl text-[#f0dfc0] lg:text-7xl xl:text-8xl">{circleSubheading}</span>
              </h4>

              <p class="mt-3 max-w-60 font-poppins text-[0.7rem] uppercase tracking-[0.22em] text-white/85">
                subtelna pigmentacja i naturalny kontur
              </p>

              <div class="mt-4 flex items-center gap-2">
                <span class="font-poppins text-lg font-light text-white">5.0</span>
                <span class="text-lg leading-none tracking-[0.08em] text-[#e4cda8]">★★★★★</span>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="animate-slide-in-right-delayed grid max-w-5xl grid-cols-1 gap-3 sm:grid-cols-3">
        {badges.map((badge) => (
          <div class="flex items-center gap-3 border border-white/25 bg-black/35 px-3 py-2.5 backdrop-blur-[1.5px]">
            <Image
              src={badge.src}
              alt={badge.alt}
              class="h-10 w-22 shrink-0 object-contain"
              loading="eager"
              quality="high"
            />
            <p class="font-poppins text-[0.62rem] uppercase leading-tight tracking-[0.17em] text-white/90 sm:text-[0.66rem]">
              {badge.label}
            </p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
