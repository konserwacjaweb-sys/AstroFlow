---
import { Image } from 'astro:assets';
import heroImage from '../../assets/back-1.jpg';

export interface Props {
  heading?: string;
  subheading?: string;
}

const {
  heading = "Piękno w Każdym Detalu",
  subheading = "Profesjonalne usługi makijażu permanentnego & powiększania ust",
} = Astro.props;
---

<section class="relative w-full min-h-screen flex items-center justify-center overflow-hidden">
  <!-- Background Image -->
  <Image
    src={heroImage}
    alt="Makijaz permanentny"
    class="absolute inset-0 w-full h-full object-cover object-top"
    loading="eager"
    quality="high"
  />

  <!-- Overlay -->
  <div class="absolute inset-0 bg-black/40"></div>

  <!-- Content -->
  <div class="container mx-auto px-4 sm:px-6 lg:px-8 relative z-10 pt-32">
    <div class="flex flex-col items-center text-center max-w-6xl mx-auto">
      <!-- Heading -->
      <h1 class="tracking-wider leading-3 text-transform:uppercase text-white leading-tight mb-4 sm:mb-6 drop-shadow-lg">
        Piękno w każdym<br/>
        <span class="italic lowercase text-6xl sm:text-7xl md:text-8xl lg:text-9xl">Detalu</span>
      </h1>

      <!-- Subheading -->
      <p class="!text-[1.4rem] tracking-[0.3em] uppercase font-light text-white/90 mb-8 sm:mb-12 drop-shadow-md max-w-2xl">
        {subheading}
      </p>

      <!-- Buttons -->
      <div class="flex flex-col sm:flex-row gap-20 w-full sm:w-auto">
        <button
          class="inline-flex items-center justify-center border-2 border-[#999173] rounded-lg hover:bg-transparent transition-all duration-200 active:scale-95 px-6 py-4 text-base uppercase bg-secondary-600 text-white hover:bg-secondary-700"
          type="button"
        >
          Makijaz Permanentny
        </button>
        <button
          class="inline-flex items-center justify-center rounded-lg bg-[#999173] border-2 border-[#999173] transition-all duration-200 shadow-md hover:shadow-lg active:scale-95 px-6 py-4 text-base uppercase bg-primary-800 text-white hover:bg-primary-900"
          type="button"
        >
          Powiększanie Ust
        </button>
      </div>
    </div>
  </div>
</section>
