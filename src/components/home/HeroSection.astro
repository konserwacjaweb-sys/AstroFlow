---
import { Image } from 'astro:assets';
import HeroButtons from '../react/HeroButtons';
import heroImage from '../../assets/back-1.jpg';

export interface Props {
  heading?: string;
  subheading?: string;
}

const {
  heading = "Piękno w Każdym Detalu",
  subheading = "Profesjonalne usługi makijażu permanentnego i powiększania ust",
} = Astro.props;
---

<section class="relative w-full min-h-screen flex items-center justify-center overflow-hidden">
  <!-- Background Image -->
  <Image
    src={heroImage}
    alt="Makijaz permanentny"
    class="absolute inset-0 w-full h-full object-cover object-top"
    loading="eager"
    quality="high"
  />

  <!-- Overlay -->
  <div class="absolute inset-0 bg-black/40"></div>

  <!-- Content -->
  <div class="container mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="flex flex-col items-center text-center max-w-3xl mx-auto">
      <!-- Heading -->
      <h1 class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-bold text-white leading-tight mb-4 sm:mb-6 drop-shadow-lg">
        {heading}
      </h1>

      <!-- Subheading -->
      <p class="text-lg sm:text-xl md:text-2xl text-white/90 mb-8 sm:mb-12 drop-shadow-md max-w-2xl">
        {subheading}
      </p>

      <!-- Buttons -->
      <HeroButtons client:idle />
    </div>
  </div>
</section>
