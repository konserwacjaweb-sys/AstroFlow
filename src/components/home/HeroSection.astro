---
import { Image } from 'astro:assets';
import heroImage from '../../assets/bg-4.jpg';
import circleGoldBg from '../../assets/circlegoldbg.png';

export interface Props {
  heading?: string;
  subheading?: string;
  circleHeading?: string;
  circleSubheading?: string;
}

const defaultHeading = "Piękno w Każdym Detalu";

const {
  heading = defaultHeading,
  subheading = "Zaoszczędź czas przed lustrem i wyglądaj pięknie 24/7",
  circleHeading = "Naturalny Efekt",
  circleSubheading = "Podkreśl swoje piękno subtelnie i elegancko",
} = Astro.props;

const useDefaultHeading = heading === defaultHeading;
---

<section class="relative w-auto h-[70vh] md:h-screen lg:h-screen flex items-center justify-center overflow-hidden">
  <!-- Background Image -->
  <Image
    src={heroImage}
    alt="Makijaz permanentny"
    class="absolute inset-0 w-full h-full object-cover object-top"
    loading="eager"
    quality="high"
  />

  <!-- Content -->
  <div class="w-full px-8 relative z-10 pt-18 sm:pt-44 lg:pt-52 pb-12 sm:pb-16">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 sm:gap-10 lg:gap-16 items-center ">
      <div class="text-left">
        <h1 class="font-notoDisplay font-normal leading-tight uppercase text-white mb-4 sm:mb-6 drop-shadow-sm text-5xl md:text-5xl lg:text-5xl">
          {useDefaultHeading ? (
            <>
              Top permanent <br />makeup<span class="absolute left-[35%] top-[12%] md:left-[42%] md:top-[15%] lg:left-[53%] lg:top-[15%] -translate-x-1/2 -translate-y-1/2 text-[150px] md:text-[250px] lg:text-[306px] opacity-35 leading-none pointer-events-none italic text-white/60">&</span> <br />Powiększanie ust
            </>
          ) : (
            heading
          )}
        </h1>
        <p class="text-sm md:text-base tracking-[0.16em] uppercase font-light text-white/90 drop-shadow-md max-w-xl mx-0">
          {subheading}
        </p>
      </div>

      <div class="relative w-full h-56 sm:h-72 md:h-80 hidden md:flex items-center justify-end">
        <div class="absolute right-0 sm:right-0 md:right-0 lg:right-0 top-[55%] sm:top-1/2 -translate-y-1/2 h-32 w-32 sm:h-48 sm:w-48 md:h-64 md:w-64 lg:h-80 lg:w-80">
          <Image
            src={circleGoldBg}
            alt="Złote koło dekoracyjne"
            class="w-full h-full object-contain"
            loading="eager"
            quality="high"
          />
        </div>

        <div class="flex flex-col items-end text-right">
          <h4 class="font-notoDisplay text-white text-lg sm:text-2xl lg:text-4xl font-normal leading-tight mb-2 sm:mb-3 max-w-70">
            Naturalny <br/><span class="text-6xl">Efekt</span>
          </h4>
          <div class="mb-2 sm:mb-3 flex items-center gap-2">
            <span class=" text-white sm:text-lg font-extralight  leading-none">5.0</span>
            <span class=" text-[#89112a] sm:text-lg font-extralight leading-none tracking-[0.08em]">★★★★★</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
