---
import { Phone } from 'lucide-react';
import { FontAwesomeIcon } from '@fortawesome/react-fontawesome';
import { faLocationDot, faStar } from '@fortawesome/free-solid-svg-icons';
import infoBorderlessIcon from '../../assets/info-borderless.svg';

interface Props {
  inHeader?: boolean;
}

const { inHeader = false } = Astro.props;

const wrapperClasses = inHeader
  ? 'flex items-center justify-end text-xs'
  : 'flex items-center justify-end text-sm sm:text-base';

const rowClasses = inHeader
  ? 'flex items-center justify-end gap-5'
  : 'flex flex-wrap items-center justify-center md:justify-end gap-10 sm:gap-6 lg:gap-8 mx-auto py-4 sm:py-12 lg:py-20';

const linkClasses = inHeader
  ? 'inline-flex items-center gap-3 text-white/90 hover:text-[#999173] transition-colors'
  : 'inline-flex items-center gap-3 sm:gap-4 text-slate-600 hover:text-blue-600 transition-colors';
---

<div class={wrapperClasses}>
  <div class={rowClasses}>
    <a
      href="/specjalne"
      class={linkClasses}
    >
      <FontAwesomeIcon icon={faStar} className="h-3 w-3" />
      <span>Oferty Specjalne</span>
    </a>
    <a
      href="/informacje-dla-klienta"
      class={linkClasses}
    >
      <img src={infoBorderlessIcon.src} alt="" aria-hidden="true" class="h-3 w-3" />
      <span>Informacje dla Klienta</span>
    </a>
    <a
      href="tel:+48695239434"
      class={linkClasses}
    >
      <Phone className="h-3 w-3" fill="currentColor" />
      <span>Gabinet Kościerzyna</span>
    </a>
    <a
      href="https://maps.app.goo.gl/sGgGBwZ52NhQ6kCN9"
      class={linkClasses}
    >
      <FontAwesomeIcon icon={faLocationDot} className="h-3 w-3" />
      <span>Znajdź lokalizację</span>
    </a>
  </div>
</div>