---
import { Image } from 'astro:assets';
import warehouseImg from '@assets/photo-1566576721346-d4a3b4eaeb55.jpg';
import distributionImg from '@assets/photo-1586528116311-ad8dd3c8310d.jpg';
---

<section class="py-24 bg-white">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <div class="inline-block px-4 py-2 mb-4 bg-teal-100 text-teal-800 text-sm font-semibold rounded-full">
        Our Infrastructure
      </div>
      <h2 class="text-4xl md:text-5xl font-bold text-slate-900 mb-6">
        Przejrzysty <span class="text-transparent bg-clip-text bg-linear-to-r from-blue-600 to-teal-600">Cennik</span>
      </h2>
      <p class="text-xl text-slate-600 max-w-3xl mx-auto leading-relaxed">
        State-of-the-art infrastructure and cutting-edge technology designed for 
        operational excellence across all our global locations.
      </p>
    </div>

    <div class="imagegrid-split">
      <div class="imagegrid-panel imagegrid-left">
        <div class="imagegrid-card">
          <Image
            src={warehouseImg}
            alt="Automated warehouse with modern robotics"
            class="imagegrid-image"
            width={1400}
            height={900}
            decoding="async"
          />
          <div class="imagegrid-overlay"></div>
          <div class="imagegrid-content">
            <h3 class="text-2xl font-bold mb-2">Automated Warehousing</h3>
            <p class="text-gray-200">Advanced robotics and AI-powered inventory management</p>
          </div>
        </div>
      </div>
      <div class="imagegrid-panel imagegrid-right">
        <div class="imagegrid-card">
          <Image
            src={distributionImg}
            alt="Distribution center with sorting systems"
            class="imagegrid-image"
            width={1200}
            height={900}
            decoding="async"
          />
          <div class="imagegrid-overlay"></div>
          <div class="imagegrid-content">
            <h3 class="text-2xl font-bold mb-2">Distribution Hub</h3>
            <p class="text-gray-200">High-speed sorting and cross-docking</p>
          </div>
        </div>
      </div>
    </div>
    
    <!-- Bottom CTA -->
    <div class="text-center mt-16">
      <a 
        href="/cennik" 
        class="inline-flex items-center px-8 py-4 text-base font-semibold text-white bg-linear-to-r from-teal-600 to-teal-700 hover:from-teal-700 hover:to-teal-800 rounded-lg shadow-lg hover:shadow-xl transition-all group"
      >
        Poznaj cennik
        <svg class="w-5 h-5 ml-2 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>
  </div>
</section>

