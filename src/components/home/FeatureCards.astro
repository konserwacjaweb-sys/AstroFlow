---
import { Image, getImage } from 'astro:assets';
import image1 from '@assets/photo-1522071820081-009f0129c71c.jpg';
import image2 from '@assets/photo-1518770660439-4636190af475.jpg';
import image3 from '@assets/photo-1450101499163-c8848c66ca85.jpg';

// Generowanie zoptymalizowanych obrazów
const image1Optimized = await getImage({ src: image1 });
const image2Optimized = await getImage({ src: image2 });
const image3Optimized = await getImage({ src: image3 });

const cards = [
  {
    title: 'Finansowanie',
    description: 'Sprawdź nasze opcje finansowania usług',
    href: '/finansowanie',
    imageSrc: image1Optimized.src
  },
  {
    title: 'Blog',
    description: 'Przeczytaj nasze artykuły i porady',
    href: '/blog',
    imageSrc: image2Optimized.src
  },
  {
    title: 'Oferta Specjalna',
    description: 'Odkryj eksklusywne promocje',
    href: '/oferta-specjalna',
    imageSrc: image3Optimized.src
  }
];
---

<section class="py-16 lg:py-24 bg-white">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
      {cards.map((card) => (
        <a 
          href={card.href}
          class="group relative h-64 lg:h-72 rounded-3xl overflow-hidden shadow-lg hover:shadow-2xl transition-all duration-300 transform hover:-translate-y-1"
        >
          {/* Background Image */}
          <div
            class="absolute inset-0"
            style={{
              backgroundImage: `url(${card.imageSrc})`,
              backgroundSize: 'cover',
              backgroundPosition: 'center'
            }}
          />
          
          {/* Overlay */}
          <div class="absolute inset-0 bg-linear-to-t from-black/80 via-black/40 to-transparent group-hover:from-black/70 transition-all duration-300"></div>
          
          {/* Content */}
          <div class="absolute inset-0 flex flex-col justify-end p-6 lg:p-8">
            <h3 class="text-2xl lg:text-3xl font-bold text-white mb-2 group-hover:text-blue-200 transition-colors duration-300">
              {card.title}
            </h3>
            <p class="text-white/90 text-sm lg:text-base group-hover:text-white transition-colors duration-300">
              {card.description}
            </p>
          </div>

          {/* Hover Arrow Indicator */}
          <div class="absolute top-6 right-6 bg-white/80 text-slate-900 rounded-full p-3 group-hover:bg-blue-600 group-hover:text-white transition-all duration-300 transform group-hover:translate-x-1 group-hover:-translate-y-1">
            <svg 
              class="w-5 h-5" 
              fill="none" 
              stroke="currentColor" 
              viewBox="0 0 24 24"
            >
              <path 
                stroke-linecap="round" 
                stroke-linejoin="round" 
                stroke-width="2" 
                d="M13 7l5 5m0 0l-5 5m5-5H6" 
              />
            </svg>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
