---
import { Image, getImage } from 'astro:assets';
import image1 from '@assets/finansowanie.jpg';
import image2 from '@assets/blog.jpg';
import image3 from '@assets/oferta.jpg';

// Generowanie zoptymalizowanych obrazów
const image1Optimized = await getImage({ src: image1 });
const image2Optimized = await getImage({ src: image2 });
const image3Optimized = await getImage({ src: image3 });

const cards = [
  {
    title: 'Finansowanie',
    href: '/finansowanie',
    imageSrc: image1Optimized.src
  },
  {
    title: 'Blog',
    href: '/blog',
    imageSrc: image2Optimized.src
  },
  {
    title: 'Oferta Specjalna',
    href: '/oferta-specjalna',
    imageSrc: image3Optimized.src
  }
];
---

<section class="container mx-auto py-32 ">
  <div class="px-4 sm:px-6 lg:py-8">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
      {cards.map((card) => (
        <a 
          href={card.href}
          class="group relative h-64 lg:h-72 rounded-3xl overflow-hidden shadow-lg hover:shadow-2xl transition-all duration-300 transform hover:-translate-y-1"
        >
          {/* Background Image */}
          <div
            class="absolute inset-0"
            style={{
              backgroundImage: `url(${card.imageSrc})`,
              backgroundSize: 'cover',
              backgroundPosition: 'center'
            }}
          />
          
          {/* Overlay */}
          <div class="absolute inset-0  bg-black/40 group-hover:from-black/70 transition-all duration-300"></div>
          
          {/* Content */}
          <div class="absolute inset-0 flex flex-col items-center justify-center p-6 lg:p-8 text-center">
            <h4 class="font-notoDisplay text-2x1 text-white group-hover:text-blue-200 transition-colors duration-300">
              {card.title}
            </h4>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
