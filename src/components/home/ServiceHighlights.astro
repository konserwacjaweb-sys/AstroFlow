---
import FeatureShowcase from '../react/FeatureShowcase';
---

<section class="py-24 bg-slate-50">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <h2 class="text-4xl md:text-5xl font-bold text-slate-900 mb-6">
        Comprehensive Solutions</span>
      </h2>
      <p class="text-[1.5rem] leading-[1.7] text-slate-600 max-w-3xl mx-auto font-heading font-normal italic">
        Ten salon kosmetyczny wyróżnia się profesjonalnym podejściem i przyjazną atmosferą, którą czuć już od pierwszej wizyty. Zabiegi wykonywane są bardzo starannie, z dbałością o każdy detal. Z przyjemnością wrócę ponownie.
      </p>
      <span class="block mt-[0.45em] text-[0.75rem] font-semibold tracking-[3px] uppercase p-6">- To najczęstsza opinia naszych klientek.</span>
    </div>

    <FeatureShowcase client:load />
    
    <!-- Bottom CTA -->
    <div class="text-center mt-16">
      <a 
        href="/uslugi" 
        class="inline-flex items-center px-8 py-4 text-base font-semibold text-white bg-linear-to-r from-blue-600 to-blue-700 hover:from-blue-700 hover:to-blue-800 rounded-lg shadow-lg hover:shadow-xl transition-all group"
      >
        Poznaj wszystkie usługi
        <svg class="w-5 h-5 ml-2 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>
  </div>
</section>

