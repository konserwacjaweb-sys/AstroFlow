---
import { Image, getImage } from 'astro:assets';
import SliderControls from '../react/SliderControls.tsx';
import makijazBrwiImg from '@assets/makijaz_permanentny_koscierzyna_beauty.jpg';
import powiekszanieUstImg from '@assets/powiekszanie_ust_koscierzyna_beauty.jpg';

// Generowanie zoptymalizowanych obrazów
const makijazBrwiOptimized = await getImage({ src: makijazBrwiImg });
const powiekszanieUstOptimized = await getImage({ src: powiekszanieUstImg });

// Definicja danych slajdów - statyczna część (Astro)
const slides = [
  {
    id: 1,
    title: 'Makijaż Permanentny Brwi',
    description: 'Profesjonalny makijaż permanentny brwi metodą pudrową. Naturalny efekt na lata. Bezbolesna procedura z wykorzystaniem najnowocześniejszych urządzeń i pigmentów najwyższej jakości.',
    imageSrc: makijazBrwiOptimized.src,
    imageAlt: 'Makijaż permanentny brwi'
  },
  {
    id: 2,
    title: 'Powiększanie Ust',
    description: 'Modelowanie i powiększanie ust kwasem hialuronowym. Naturalne rezultaty dopasowane do kształtu Twojej twarzy. Bezpieczne preparaty certyfikowane, profesjonalna obsługa.',
    imageSrc: powiekszanieUstOptimized.src,
    imageAlt: 'Powiększanie ust'
  }
];
---

<!-- Struktura sekcji (Astro) -->
<section class="sm:py-16 w-full">
  <div class="w-full">
    <h2 class="text-slate-900 mb-12 text-center">
      Beaty For You
    </h2>
    <div class="w-full">
      <!-- Interaktywne elementy (React) -->
      <SliderControls slides={slides} client:load />
    </div>
  </div>
</section>
