---
import type { ImageMetadata } from 'astro';
import GalleryCarouselClient from '../react/GalleryCarousel';
import imageBg from '@assets/baa586bg.jpg';
import makeup1 from '@assets/makeup-wiktoria.jpg';
import makeup2 from '@assets/makeup-wiktoria-2.jpg';
import medspa from '@assets/medspa.jpg';

interface SlideItem {
  src: ImageMetadata;
  alt: string;
  description: string;
}

interface Props {
  slides?: SlideItem[];
  buttonHref?: string;
  buttonLabel?: string;
}

const {
  slides: inputSlides,
  buttonHref = '/galeria',
  buttonLabel = 'Przejdz do galerii'
} = Astro.props as Props;

const defaultSlides: SlideItem[] = [
  {
    src: makeup1,
    alt: 'Makijaz permanentny brwi',
    description: 'Naturalny efekt dopasowany do rysow twarzy.'
  },
  {
    src: makeup2,
    alt: 'Makijaz permanentny ust',
    description: 'Delikatne podkreslenie koloru i konturu ust.'
  },
  {
    src: medspa,
    alt: 'Strefa beauty',
    description: 'Komfortowa przestrzen zabiegowa i profesjonalna opieka.'
  }
];

const slides = inputSlides && inputSlides.length > 0 ? inputSlides : defaultSlides;

const clientSlides = slides.map((slide) => ({
  src: slide.src.src,
  alt: slide.alt,
  description: slide.description
}));
---
<section
  class="bg-cover bg-center bg-no-repeat px-6 py-14 sm:px-8 lg:px-12"
  style={`background-image: url(${imageBg.src});`}
>
  <div class="mx-auto w-full max-w-5xl">
    <h1 class="font-poppins text-center tracking-[0.5em] text-md font-medium uppercase text-[#baa586]">
     Konsultacje w zakresie makijazu permanentnego i modelowania ust w Koscierzynie i Wejherowie.
    </h1>

    <hr class="mx-auto mt-6 h-px w-full max-w-3xl border-0 bg-[#c1b599] my-10" />

    <p class="text-4xl leading-relaxed mt-4 font-poppins font-extralight text-center ">
      Konsultacje z
      <span class="italic">Wioletą Literską.</span>
    </p>

    <p class="mx-auto my-9 mb-25 text-left lg:text-justify first-letter:text-8xl first-letter:float-left first-letter:mr-4 first-letter:mt-1 first-letter:font-serif first-letter:leading-[0.8] ">
      Z przyjemnością spotkam się z Tobą podczas indywidualnej konsultacji. Jeśli rozważasz makijaż permanentny lub modelowanie ust, wspólnie omówimy możliwości i dobierzemy rozwiązanie dopasowane do Twojej urody. Podczas spotkania pokażę, jakie efekty są możliwe i odpowiem na wszystkie pytania, abyś mogła podjąć decyzję w pełni świadomie i spokojnie.
    </p>
  </div>
<div class="mx-auto flex w-full flex-col items-center px-4 ">
  <GalleryCarouselClient client:load slides={clientSlides} />
</div>
  <div class="mx-auto mt-12 flex w-full max-w-5xl flex-col items-center justify-center gap-8 xl:flex-row">
    <a
      href={buttonHref}
      class="inline-flex items-center justify-center rounded-sm border-2 border-[#999173] bg-[#999173] px-6 py-3 font-normal uppercase tracking-wide text-white transition-colors hover:bg-[#999173]/90"
    >
      {buttonLabel}
    </a>
    <a
      href="/usta"
      class="inline-flex items-center justify-center rounded-sm border-2 border-[#999173] bg-[#999173] px-6 py-3 font-normal uppercase tracking-wide text-white transition-colors hover:bg-[#999173]/90"
    >
      Powiekszanie ust
    </a>
    <a
      href="/brwi"
      class="inline-flex items-center justify-center rounded-sm border-2 border-[#999173] bg-[#999173] px-6 py-3 font-normal uppercase tracking-wide text-white transition-colors hover:bg-[#999173]/90"
    >
      Makijaz permanentny
    </a>
  </div>
</section>
