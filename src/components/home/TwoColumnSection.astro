---
import { Image } from 'astro:assets';
import exampleImg from '@assets/photo-1450101499163-c8848c66ca85.jpg';
import sliderImg1 from '@assets/3.jpg';
import sliderImg2 from '@assets/5.jpg';
import sliderImg3 from '@assets/15.jpg';
import sliderImg4 from '@assets/makijaz_permanentny_koscierzyna_beauty.jpg';
import sliderImg5 from '@assets/powiekszanie_ust_koscierzyna_beauty.jpg';
---

<section class="py-24 bg-white">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex min-h-[320px] flex-col overflow-hidden md:flex-row md:gap-8">
      <!-- First Column - 55% -->
      <div class="relative flex-none min-h-[320px] basis-full md:basis-[55%] rounded-4xl overflow-hidden">
        <Image
          src={exampleImg}
          alt="Background image"
          class="absolute inset-0 h-full w-full object-cover"
          width={1000}
          height={600}
          decoding="async"
        />
        <div class="absolute inset-0 bg-black/40" />
        <div class="relative flex h-full flex-col items-center justify-center p-8 text-center">
          <span class="text-white/80 text-lg mb-4">Przykładowy tekst span</span>
          <h2 class="text-3xl font-bold text-white mb-4">Przykładowy nagłówek h2</h2>
        </div>
      </div>

      <!-- Second Column - 45% -->
      <div class="relative flex-none min-h-[320px] basis-full md:basis-[45%] rounded-4xl bg-gray-100 grid place-items-center">
        <div class="two-column-carousel-wrap w-full h-full flex items-center justify-center px-6">
          <button
            type="button"
            class="two-column-carousel-prev flex-shrink-0 z-20 inline-flex h-10 w-10 items-center justify-center rounded-full bg-white/80 text-slate-900 shadow-lg backdrop-blur transition hover:bg-white mr-4"
            aria-label="Poprzednie zdjecie"
          >
            <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M15 18l-6-6 6-6" />
            </svg>
          </button>
          <div class="two-column-carousel relative h-[250px] w-full max-w-[320px] overflow-hidden rounded-3xl">
            <div class="absolute inset-0">
              <Image
                src={sliderImg1}
                alt="Slider image 1"
                class="two-column-slide absolute inset-0 h-full w-full object-cover opacity-100 transition-opacity duration-700 ease-out"
                data-slide="0"
                width={400}
                height={300}
                decoding="async"
                loading="lazy"
              />
              <Image
                src={sliderImg2}
                alt="Slider image 2"
                class="two-column-slide absolute inset-0 h-full w-full object-cover opacity-0 transition-opacity duration-700 ease-out"
                data-slide="1"
                width={400}
                height={300}
                decoding="async"
                loading="lazy"
              />
              <Image
                src={sliderImg3}
                alt="Slider image 3"
                class="two-column-slide absolute inset-0 h-full w-full object-cover opacity-0 transition-opacity duration-700 ease-out"
                data-slide="2"
                width={400}
                height={300}
                decoding="async"
                loading="lazy"
              />
              <Image
                src={sliderImg4}
                alt="Slider image 4"
                class="two-column-slide absolute inset-0 h-full w-full object-cover opacity-0 transition-opacity duration-700 ease-out"
                data-slide="3"
                width={400}
                height={300}
                decoding="async"
                loading="lazy"
              />
              <Image
                src={sliderImg5}
                alt="Slider image 5"
                class="two-column-slide absolute inset-0 h-full w-full object-cover opacity-0 transition-opacity duration-700 ease-out"
                data-slide="4"
                width={400}
                height={300}
                decoding="async"
                loading="lazy"
              />
            </div>
          </div>
          <button
            type="button"
            class="two-column-carousel-next flex-shrink-0 z-20 inline-flex h-10 w-10 items-center justify-center rounded-full bg-white/80 text-slate-900 shadow-lg backdrop-blur transition hover:bg-white ml-4"
            aria-label="Nastepne zdjecie"
          >
            <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M9 18l6-6-6-6" />
            </svg>
          </button>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  const carouselWrap = document.querySelector('.two-column-carousel-wrap');
  if (carouselWrap) {
    const carousel = carouselWrap.querySelector('.two-column-carousel');
    const slides = Array.from(carousel.querySelectorAll('.two-column-slide'));
    const prevButton = carouselWrap.querySelector('.two-column-carousel-prev');
    const nextButton = carouselWrap.querySelector('.two-column-carousel-next');
    let currentIndex = 0;

    const setActive = (index) => {
      currentIndex = (index + slides.length) % slides.length;
      slides.forEach((slide, slideIndex) => {
        const isActive = slideIndex === currentIndex;
        slide.classList.toggle('opacity-100', isActive);
        slide.classList.toggle('opacity-0', !isActive);
        slide.classList.toggle('z-10', isActive);
        slide.setAttribute('aria-hidden', isActive ? 'false' : 'true');
      });
    };

    const goNext = () => setActive(currentIndex + 1);
    const goPrev = () => setActive(currentIndex - 1);

    setActive(0);

    prevButton?.addEventListener('click', () => {
      goPrev();
    });
    nextButton?.addEventListener('click', () => {
      goNext();
    });
  }
</script>
