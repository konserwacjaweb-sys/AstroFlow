---
import { Image } from 'astro:assets';
import TwoColumnsBlock from '../react/TwoColumnsBlock';
import leftBg from '../../assets/Beauty.png';
import rightBg from '../../assets/m-2.jpg';

interface Props {
  leftTitle?: string;
  leftText?: string;
  pText?: string;
  leftButton?: string;
  rightTitle?: string;
  rightText?: string;
  rightButton?: string;
}

const {
  leftTitle = 'Makijaż Permanentny',
  leftText = 'Subtelny efekt, który podkreśla Twoje naturalne piękno.',
  pText = 'Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do eiusmod tempor incididunt ut labore et dolore magna aliqua. Ut enim ad minim veniam, quis nostrud exercitation ullamco laboris nisi ut aliquip ex ea commodo consequat. Duis aute irure dolor in reprehenderit in voluptate velit esse cillum dolore eu fugiat nulla pariatur. Excepteur sint occaecat cupidatat non proident, sunt in culpa qui officia deserunt mollit anim id est laborum.',
  leftButton = 'Umów wizytę',
  rightTitle = 'Powiększanie Ust',
  rightText = 'Harmonijny kontur i objętość dopasowane do Twoich rysów.',
  rightButton = 'Sprawdź ofertę',
} = Astro.props;
---

<section class="relative w-full overflow-hidden">
  <Image
    src={leftBg}
    alt="Tło makijażu permanentnego"
    class="absolute inset-0 h-full w-full object-contain object-[center_150px]"
    loading="lazy"
    quality="high"
  />

  <div class="relative container mx-auto grid grid-cols-1 md:grid-cols-2">
    <article class="relative isolate">

      <TwoColumnsBlock
        subtitle={leftText}
        title={leftTitle}
        text={pText}
        buttonLabel={leftButton}
        className="justify-center px-5 pt-10 pb-20 md:px-20 md:pt-15 md:pb-25 lg:pt-20 lg:pb-30"
        subtitleClassName="subheading text-slate-900 pb-4"
        titleClassName="text-slate-900 pb-5"
        textClassName="max-w-md text-slate-900"
        buttonClassName="text-white uppercase bg-[#999173] hover:bg-[#999173]/90 transition-colors"
      />
    </article>

    <article class="relative isolate md:h-full">
      <Image
        src={rightBg}
        alt="Tło powiększania ust"
        class="absolute inset-0 h-full w-full object-cover"
        loading="lazy"
        quality="high"
      />

      <div class="absolute inset-0 bg-black/45"></div>

      <TwoColumnsBlock
        title={rightTitle}
        headingTag="h3"
        text={rightText}
        buttonLabel={rightButton}
        className="justify-end px-6 py-10 sm:px-10 md:px-12 animate-slide-in-right will-change-transform"
        titleClassName="text-white"
        textClassName="max-w-md text-sm text-white/90 sm:text-base"
        buttonClassName="text-white uppercase bg-[#999173] hover:bg-[#999173]/90 transition-colors"
      />
    </article>

  </div>
</section>