---
import { Image } from 'astro:assets';
import { Phone } from 'lucide-react';
import { FontAwesomeIcon } from '@fortawesome/react-fontawesome';
import { faLocationDot, faStar, faCircleInfo } from '@fortawesome/free-solid-svg-icons';
import leftBg from '../../assets/makijaz_permanentny_koscierzyna_beauty.jpg';
import rightBg from '../../assets/powiekszanie_ust_koscierzyna_beauty.jpg';

interface Props {
  leftTitle?: string;
  leftText?: string;
  leftButton?: string;
  rightTitle?: string;
  rightText?: string;
  rightButton?: string;
}

const {
  leftTitle = 'Makijaż Permanentny',
  leftText = 'Subtelny efekt, który podkreśla Twoje naturalne piękno.',
  leftButton = 'Umów wizytę',
  rightTitle = 'Powiększanie Ust',
  rightText = 'Harmonijny kontur i objętość dopasowane do Twoich rysów.',
  rightButton = 'Sprawdź ofertę'
} = Astro.props;
---

<section class="w-full overflow-hidden">
  <div class="w-full">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex h-10 items-center justify-end text-x1">
        <div class="flex items-center gap-8">
          <a
            href="/specjalne"
            class="hidden lg:inline-flex items-center gap-4 text-slate-600 hover:text-blue-600 transition-colors"
          >
            <FontAwesomeIcon icon={faStar} className="h-4 w-4" />
            <span>Oferty Specjalne</span>
          </a>
          <a
            href="/informacje-dla-klienta"
            class="hidden lg:inline-flex items-center gap-4 text-slate-600 hover:text-blue-600 transition-colors"
          >
            <FontAwesomeIcon icon={faCircleInfo} className="h-4 w-4" />
            <span>Informacje dla Klienta</span>
          </a>
          <a
            href="tel:+48695239434"
            class="hidden md:inline-flex items-center gap-4 text-slate-600 hover:text-blue-600 transition-colors"
          >
            <Phone className="h-4 w-4" fill="currentColor" />
            <span>Gabinet Kościerzyna<br/>+48 695 239 434</span>
          </a>
          <a
            href="https://maps.app.goo.gl/sGgGBwZ52NhQ6kCN9"
            class="inline-flex items-center gap-4 text-slate-600 hover:text-blue-600 transition-colors"
          >
            <FontAwesomeIcon icon={faLocationDot} className="h-4 w-4" />
            <span class="hidden sm:inline">Znajdź lokalizację</span>
          </a>
        </div>
      </div>
    </div>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2">
    <article class="relative isolate min-h-[380px] md:min-h-[520px] overflow-hidden">
      <Image
        src={leftBg}
        alt="Tło makijażu permanentnego"
        class="absolute inset-0 h-full w-full object-cover"
        loading="lazy"
        quality="high"
      />
      <div class="absolute inset-0 bg-black/45"></div>

      <div class="relative z-10 flex h-full flex-col items-start justify-end gap-4 px-6 py-10 sm:px-10 md:px-12 motion-safe:animate-[slideInLeft_900ms_cubic-bezier(0.16,1,0.3,1)_both] will-change-transform">
        <h2 class="text-white">{leftTitle}</h2>
        <span class="max-w-md text-sm text-white/90 sm:text-base">{leftText}</span>
        <button class="inline-flex items-center justify-center rounded-lg bg-white px-6 py-3 font-semibold text-primary-800 transition-colors duration-200 hover:bg-white/90 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-white/80 focus-visible:ring-offset-2 focus-visible:ring-offset-black/30">
          {leftButton}
        </button>
      </div>
    </article>

    <article class="relative isolate min-h-[380px] md:min-h-[520px] overflow-hidden">
      <Image
        src={rightBg}
        alt="Tło powiększania ust"
        class="absolute inset-0 h-full w-full object-cover"
        loading="lazy"
        quality="high"
      />
      <div class="absolute inset-0 bg-black/45"></div>

      <div class="relative z-10 flex h-full flex-col items-start justify-end gap-4 px-6 py-10 sm:px-10 md:px-12 motion-safe:animate-[slideInRight_900ms_cubic-bezier(0.16,1,0.3,1)_both] will-change-transform">
        <h2 class="text-white">{rightTitle}</h2>
        <span class="max-w-md text-sm text-white/90 sm:text-base">{rightText}</span>
        <button class="inline-flex items-center justify-center rounded-lg bg-white px-6 py-3 font-semibold text-primary-800 transition-colors duration-200 hover:bg-white/90 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-white/80 focus-visible:ring-offset-2 focus-visible:ring-offset-black/30">
          {rightButton}
        </button>
      </div>
    </article>
  </div>
</section>

<style>
  @keyframes slideInLeft {
    from {
      opacity: 0;
      transform: translate3d(-32px, 0, 0);
    }
    to {
      opacity: 1;
      transform: translate3d(0, 0, 0);
    }
  }

  @keyframes slideInRight {
    from {
      opacity: 0;
      transform: translate3d(32px, 0, 0);
    }
    to {
      opacity: 1;
      transform: translate3d(0, 0, 0);
    }
  }
</style>