---
import { Image } from 'astro:assets';
import logoMain from '../../assets/art-beauty-logo.png';
import logoCircle from '../../assets/pmugold.png';
import logoGold from '../../assets/HJ.png';

const logos = [
  { src: logoMain, alt: 'Wioleta Literska - logo główne' },
  { src: logoCircle, alt: 'Wioleta Literska - logo okrągłe' },
  { src: logoGold, alt: 'Wioleta Literska - logo złote' },
];

const loopedLogos = [...logos, ...logos];
---

<section class="py-12 overflow-hidden" aria-label="Karuzela logotypów">
  <div class="container mx-auto">
    <div class="relative w-full overflow-hidden">
      <div class="flex w-fit gap-8 sm:gap-16 will-change-transform [animation:scroll_30s_linear_infinite] hover:[animation-play-state:paused] motion-reduce:[animation:none] motion-reduce:transform-none" role="list">
        {loopedLogos.map((logo, index) => {
          const isDuplicate = index >= logos.length;

          return (
            <div class="flex min-w-[120px] sm:min-w-[150px] flex-shrink-0 items-center justify-center" role="listitem" aria-hidden={isDuplicate ? 'true' : 'false'}>
              <Image
                src={logo.src}
                alt={isDuplicate ? '' : logo.alt}
                class="h-11.25 lg:h-14 w-auto object-contain transition-all duration-300"
                loading="lazy"
                quality="high"
              />
            </div>
          );
        })}
      </div>
    </div>
  </div>
</section>
