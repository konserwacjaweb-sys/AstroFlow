---
import { Image } from 'astro:assets';
import logo from '@assets/logo_jednolite.png';
import img1 from '@assets/makijaz_permanentny_koscierzyna_beauty.jpg';
import img2 from '@assets/photo-1460925895917-afdab827c52f.jpg';
import img3 from '@assets/photo-1486312338219-ce68d2c6f44d.jpg';
import img4 from '@assets/powiekszanie_ust_koscierzyna_beauty.jpg';

const links = [
  { label: 'Makijaż permanentny', href: '/oferta#makijaz' },
  { label: 'Powiększanie ust', href: '/oferta#usta' },
  { label: 'Projektowanie brwi', href: '/oferta#brwi' },
  { label: 'Korekta brwi', href: '/oferta#korekta' },
  { label: 'Stylizacja henna', href: '/oferta#henna' },
  { label: 'Konsultacja', href: '/oferta#konsultacja' }
];
---

<section class="min-h-[600px] py-16 lg:py-24">
  <div class="container mx-auto">
    <div class="grid grid-cols-1 lg:grid-cols-[45%_55%] gap-8 items-stretch">
      {/* Left Column - Astro Island Layout */}
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-4 auto-rows-[200px]">
        {/* Item 1 - High, column 1, rows 1-2 */}
        <div 
          class="rounded-3xl overflow-hidden shadow-lg lg:row-span-2"
          style={{
            backgroundImage: `url(${img1.src})`,
            backgroundSize: 'cover',
            backgroundPosition: 'center'
          }}
        />

        {/* Item 2 - Low, column 2, row 1 */}
        <div 
          class="rounded-3xl overflow-hidden shadow-lg"
          style={{
            backgroundImage: `url(${img2.src})`,
            backgroundSize: 'cover',
            backgroundPosition: 'center'
          }}
        />

        {/* Item 4 - High, column 2, rows 2-3 */}
        <div 
          class="rounded-3xl overflow-hidden shadow-lg lg:row-span-2"
          style={{
            backgroundImage: `url(${img4.src})`,
            backgroundSize: 'cover',
            backgroundPosition: 'center'
          }}
        />

        {/* Item 3 - Low, column 1, row 3 */}
        <div 
          class="rounded-3xl overflow-hidden shadow-lg"
          style={{
            backgroundImage: `url(${img3.src})`,
            backgroundSize: 'cover',
            backgroundPosition: 'center'
          }}
        />
      </div>

      {/* Right Column - Content */}
      <div class="flex flex-col justify-between p-8 lg:pl-[100px] lg:pr-10 lg:py-10">
        {/* Top Section */}
        <div>
          {/* Logo */}
          <div class="mb-6 h-20 w-auto">
            <img 
              src={logo.src} 
              alt="Logo" 
              class="h-full w-auto object-contain"
            />
          </div>

          {/* Heading */}
          <h2 class="text-slate-900 mb-4">
            Nasze Oferty
          </h2>

          {/* Description */}
          <p class="text-slate-600 leading-relaxed mb-8">
            Oferujemy kompleksowe usługi makijażu permanentnego i upiększającego zabiegi dla pani cery.
          </p>

          {/* Links - Horizontal Wrapped */}
          <div class="flex flex-wrap gap-2 lg:gap-3">
            {links.map((link) => (
              <a 
                href={link.href}
                class="text-sm lg:text-base font-medium text-slate-700 hover:text-blue-600 hover:underline transition-colors py-1 px-2 rounded-lg hover:bg-slate-50"
              >
                {link.label}
              </a>
            ))}
          </div>
        </div>

        {/* Button - Bottom */}
        <a 
          href="/oferta"
          class="inline-flex items-center justify-center px-8 py-4 text-base font-semibold text-white bg-gradient-to-r from-blue-600 to-blue-700 hover:from-blue-700 hover:to-blue-800 rounded-lg shadow-lg hover:shadow-xl transition-all group w-full"
        >
          Odkryj pełną ofertę
          <svg class="w-5 h-5 ml-2 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>
    </div>
  </div>
</section>
